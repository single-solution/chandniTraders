{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "stream",
	"globalEnv": [
		"NODE_ENV",
		"LOG_LEVEL",
		"AUTH_SECRET",
		"AUTH_URL",
		"AUTH_TRUST_HOST",
		"MONGODB_URI",
		"STORAGE_PROVIDER",
		"BLOB_READ_WRITE_TOKEN",
		"AWS_S3_BUCKET",
		"AWS_S3_REGION",
		"AWS_ACCESS_KEY_ID",
		"AWS_SECRET_ACCESS_KEY",
		"AWS_S3_PUBLIC_URL_BASE",
		"OTP_PROVIDER",
		"WHATSAPP_CLOUD_ACCESS_TOKEN",
		"WHATSAPP_PHONE_NUMBER_ID",
		"WHATSAPP_OTP_TEMPLATE_NAME",
		"WHATSAPP_CLOUD_API_VERSION",
		"WHATSAPP_OTP_TEMPLATE_INCLUDES_BUTTON",
		"WHATSAPP_STAFF_NOTIFY_TEMPLATE",
		"WHATSAPP_CUSTOMER_ORDER_TEMPLATE",
		"RESEND_API_KEY",
		"RESEND_FROM_EMAIL",
		"ADMIN_SITE_URL",
		"STAFF_NOTIFY_EMAIL",
		"STAFF_NOTIFY_WHATSAPP",
		"STOREFRONT_BASE_URL",
		"NEXT_PUBLIC_STOREFRONT_URL",
		"NEXT_PUBLIC_SITE_URL",
		"OPENAI_API_KEY",
		"OPENAI_CHAT_MODEL",
		"GOOGLE_AI_API_KEY",
		"GEMINI_CHAT_MODEL",
		"ANTHROPIC_API_KEY",
		"ANTHROPIC_CHAT_MODEL",
		"ATLAS_SEARCH_ENABLED",
		"MONGODB_SEARCH_INDEX",
		"DEV_SKIP_PUBLIC_DNS",
		"MONGODB_SKIP_PUBLIC_DNS",
		"ANALYZE",
		"VERCEL_URL",
		"VERCEL_PROJECT_PRODUCTION_URL",
		"VERCEL_ENV"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "package.json", "tsconfig.json", "next.config.ts"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"],
			"env": [
				"MONGODB_URI",
				"AUTH_SECRET",
				"AUTH_URL",
				"AUTH_TRUST_HOST",
				"STOREFRONT_BASE_URL",
				"NEXT_PUBLIC_STOREFRONT_URL",
				"NEXT_PUBLIC_SITE_URL",
				"STORAGE_PROVIDER",
				"BLOB_READ_WRITE_TOKEN",
				"AWS_S3_BUCKET",
				"AWS_S3_REGION",
				"AWS_ACCESS_KEY_ID",
				"AWS_SECRET_ACCESS_KEY",
				"AWS_S3_PUBLIC_URL_BASE",
				"OTP_PROVIDER",
				"WHATSAPP_CLOUD_ACCESS_TOKEN",
				"WHATSAPP_PHONE_NUMBER_ID",
				"WHATSAPP_OTP_TEMPLATE_NAME",
				"WHATSAPP_CLOUD_API_VERSION",
				"WHATSAPP_OTP_TEMPLATE_INCLUDES_BUTTON",
				"WHATSAPP_STAFF_NOTIFY_TEMPLATE",
		"WHATSAPP_CUSTOMER_ORDER_TEMPLATE",
				"RESEND_API_KEY",
				"RESEND_FROM_EMAIL",
				"ADMIN_SITE_URL",
				"STAFF_NOTIFY_EMAIL",
				"STAFF_NOTIFY_WHATSAPP",
				"OPENAI_API_KEY",
				"OPENAI_CHAT_MODEL",
				"GOOGLE_AI_API_KEY",
				"GEMINI_CHAT_MODEL",
				"ANTHROPIC_API_KEY",
				"ANTHROPIC_CHAT_MODEL",
				"ATLAS_SEARCH_ENABLED",
				"MONGODB_SEARCH_INDEX",
				"VERCEL_URL",
				"VERCEL_PROJECT_PRODUCTION_URL",
				"VERCEL_ENV"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		}
	}
}
