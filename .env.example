# ============================================================================
# Chandni Traders — environment template
# Copy to `.env.local` at the repo root (shared by storefront + admin).
#
# Most integration secrets (PayFast, Rapid Gateway, WhatsApp, Resend, storage)
# can be managed in Admin → Settings → Integrations. Env vars below are
# bootstrap fallbacks and infrastructure that must stay on the host (MongoDB, AUTH_*).
#
# Production launch: docs/go-live.md
# ============================================================================

# ── REQUIRED — app boot ──────────────────────────────────────────────────────
# Generate AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Storefront in dev: http://localhost:3000 | Admin in dev: http://localhost:3001
AUTH_URL=
AUTH_TRUST_HOST=true
# Must include database name in path, e.g. .../chandni-traders?retryWrites=true&w=majority
MONGODB_URI=

# ── OPTIONAL bootstrap — prefer Admin → Settings → Integrations ─────────────
# ONLINE_PAYMENT_PROVIDER=none|payfast|rapid-gateway
# PAYFAST_MERCHANT_ID=
# PAYFAST_SECURED_KEY=
# PAYFAST_MERCHANT_NAME=
# PAYFAST_SANDBOX=true
# RAPID_GATEWAY_SECRET_KEY=
# RAPID_GATEWAY_WEBHOOK_SECRET=
# RAPID_GATEWAY_SANDBOX=true
# OTP_PROVIDER=whatsapp-cloud
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_OTP_TEMPLATE_NAME=authentication
# WHATSAPP_CLOUD_API_VERSION=v21.0
# WHATSAPP_OTP_TEMPLATE_INCLUDES_BUTTON=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# ADMIN_SITE_URL=https://admin.yourstore.pk
# STAFF_NOTIFY_EMAIL=
# STAFF_NOTIFY_WHATSAPP=
# WHATSAPP_STAFF_NOTIFY_TEMPLATE=
# WHATSAPP_CUSTOMER_ORDER_TEMPLATE=
# BLOB_READ_WRITE_TOKEN=
# STORAGE_PROVIDER=vercel-blob
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_PUBLIC_URL_BASE=

# ── OPTIONAL — storefront SEO / canonical URLs ───────────────────────────────
# Admin Settings → Site URLs wins when saved. Env is fallback only.
STOREFRONT_BASE_URL=
NEXT_PUBLIC_STOREFRONT_URL=
NEXT_PUBLIC_SITE_URL=

# ── OPTIONAL — WooCommerce import (scripts/chandni-import.mjs) ───────────────
# WOO_BASE_URL=https://chandnitraders.pk
# WOO_CONSUMER_KEY=
# WOO_CONSUMER_SECRET=

# ── OPTIONAL — chat assistant (storefront + admin settings validation) ───────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
GOOGLE_AI_API_KEY=
GEMINI_CHAT_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=

# ── OPTIONAL — MongoDB Atlas Search (catalog + assistant product lookup) ────
ATLAS_SEARCH_ENABLED=
MONGODB_SEARCH_INDEX=products_search

# ── OPTIONAL — local dev / tooling ──────────────────────────────────────────
DEV_SKIP_PUBLIC_DNS=
MONGODB_SKIP_PUBLIC_DNS=
LOG_LEVEL=
ANALYZE=

# ── Set by hosting (do not copy manually unless self-hosting) ────────────────
# NODE_ENV=
# VERCEL_URL=
# VERCEL_PROJECT_PRODUCTION_URL=
# VERCEL_ENV=
# NEXT_RUNTIME=
