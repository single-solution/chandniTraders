{
	"name": "chandni-traders",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.0.0"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --filter=@store/web",
		"dev:all": "turbo run dev --filter=@store/web --filter=@store/admin",
		"dev:web": "turbo run dev --filter=@store/web",
		"dev:admin": "turbo run dev --filter=@store/admin",
		"clean:next": "rm -rf apps/web/.next apps/admin/.next .turbo",
		"dev:fresh": "npm run clean:next && npm run dev:all",
		"build": "turbo run build",
		"build:web": "turbo run build --filter=@store/web",
		"build:admin": "turbo run build --filter=@store/admin",
		"start:web": "npm run start -w @store/web",
		"start:admin": "npm run start -w @store/admin",
		"lint": "turbo run lint",
		"typecheck": "turbo run typecheck",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"import:chandni": "npx tsx scripts/chandni-import.mjs",
		"import:chandni:dry": "npx tsx scripts/chandni-import.mjs --dry-run"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"prettier": "^3.6.2",
		"turbo": "^2.5.6",
		"typescript": "^6.0.3"
	},
	"packageManager": "npm@10.9.0",
	"overrides": {
		"postcss": "^8.5.11",
		"next": {
			"postcss": "^8.5.11"
		}
	}
}
